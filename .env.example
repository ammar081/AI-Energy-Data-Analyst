ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Leave DATABASE_URL unset for the built-in local SQLite path.
# DATABASE_URL=postgresql+psycopg://energy:energy@localhost:5432/energy_analytics
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_SECONDS=30
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
MAX_UPLOAD_SIZE_MB=50
AUTH_SECRET_KEY=replace-with-a-long-random-value
ACCESS_TOKEN_MINUTES=480
ALLOW_SELF_REGISTRATION=true
# Local Python runs execute Celery jobs immediately. Docker Compose overrides these for Redis-backed workers.
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_ALWAYS_EAGER=true
